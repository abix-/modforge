<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>Unityforge.Shim.Il2Cpp</AssemblyName>
    <Version>0.1.0</Version>
    <LangVersion>10.0</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <RootNamespace>Unityforge.Shim</RootNamespace>
    <DefineConstants>IL2CPP</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!-- Common sources linked from cs-shim-common (shared with the Mono shim). -->
    <Compile Include="..\cs-shim-common\Bridge.cs">
      <Link>Common\Bridge.cs</Link>
    </Compile>
    <Compile Include="..\cs-shim-common\HarmonyBridge.cs">
      <Link>Common\HarmonyBridge.cs</Link>
    </Compile>
    <Compile Include="..\cs-shim-common\Logger.cs">
      <Link>Common\Logger.cs</Link>
    </Compile>
    <Compile Include="..\cs-shim-common\InputBridge.cs">
      <Link>Common\InputBridge.cs</Link>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <!--
      BepInEx 6 IL2CPP + Il2CppInterop + HarmonyX references.
      Adjust HintPaths via -p:BepInExDir / -p:UnityDir.
      BepInExDir points at the BepInEx 6 IL2CPP install
      (`<game>/BepInEx/`). UnityDir is unused for IL2CPP (the
      managed UnityEngine assemblies are auto-generated by
      Il2CppInterop at first run).
    -->
    <Reference Include="BepInEx.Core" Condition="'$(BepInExDir)' != ''">
      <Private>false</Private>
      <HintPath>$(BepInExDir)\core\BepInEx.Core.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx.Unity.IL2CPP" Condition="'$(BepInExDir)' != ''">
      <Private>false</Private>
      <HintPath>$(BepInExDir)\core\BepInEx.Unity.IL2CPP.dll</HintPath>
    </Reference>
    <Reference Include="Il2CppInterop.Runtime" Condition="'$(BepInExDir)' != ''">
      <Private>false</Private>
      <HintPath>$(BepInExDir)\core\Il2CppInterop.Runtime.dll</HintPath>
    </Reference>
    <Reference Include="0Harmony" Condition="'$(BepInExDir)' != ''">
      <Private>false</Private>
      <HintPath>$(BepInExDir)\core\0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule" Condition="'$(BepInExDir)' != ''">
      <Private>false</Private>
      <!-- IL2CPP runtime: Il2CppInterop generates managed shims under
           BepInEx/interop/. Reference the auto-generated one. -->
      <HintPath>$(BepInExDir)\interop\UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule" Condition="'$(BepInExDir)' != ''">
      <Private>false</Private>
      <HintPath>$(BepInExDir)\interop\UnityEngine.InputLegacyModule.dll</HintPath>
    </Reference>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" PrivateAssets="all" />
  </ItemGroup>

</Project>
